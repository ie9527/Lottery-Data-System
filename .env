# ============================================================
# DeepSeek API 配置（AI对话模块）
# ============================================================
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-114514

# API 端点（一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型选择：deepseek-v4-flash（默认/便宜）或 deepseek-v4-pro（更强）
DEEPSEEK_MODEL=deepseek-v4-flash

# 是否启用 Beta 模式（Strict tool calls，开启时JSON Schema校验严格，建议先关闭）
DEEPSEEK_USE_BETA=False

# 是否开启思考模式
DEEPSEEK_THINKING_ENABLED=True

# 思考强度：high 或 max
DEEPSEEK_REASONING_EFFORT=high
